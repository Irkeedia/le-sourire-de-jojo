---
import "../styles/global.css";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import BrandBackdrop from "@/components/BrandBackdrop.astro";
import CursorTracker from "@/components/CursorTracker.astro";

interface Props {
  title: string;
  description: string;
  breadcrumb?: { href?: string; label: string }[];
  jsonLd?: Record<string, unknown>;
}

const { title, description, breadcrumb, jsonLd } = Astro.props;

const allowIndexing =
  import.meta.env.PUBLIC_ALLOW_INDEXING === "true" || import.meta.env.PUBLIC_ALLOW_INDEXING === "1";

const siteUrl = Astro.site?.href ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, siteUrl).href;

const defaultLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Le Sourire de Jojo",
  description:
    "Accompagnement social à domicile (Céline Meunier Benneji) — lien, bienveillance, dignité. Lecture, sorties, jeux, souvenirs. Montauban, Corbarieu, Tarn-et-Garonne.",
  url: siteUrl,
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Tarn-et-Garonne",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Montauban",
    addressRegion: "Occitanie",
    addressCountry: "FR",
  },
  priceRange: "$$",
};

const structured = jsonLd ?? defaultLd;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Céline Meunier Benneji, Le Sourire de Jojo, accompagnement social, lien social, bienveillance, dignité, intergénérationnel, Montauban, Corbarieu, Tarn-et-Garonne, SAP, crédit d'impôt, CESU, seniors, PMR"
    />
    {!allowIndexing && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/logo-sourire-de-jojo.png" />
    <link rel="apple-touch-icon" href="/images/logo-sourire-de-jojo.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500;600;700&family=Lato:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400..800;1,400..800&display=swap"
      rel="stylesheet"
    />
    {allowIndexing && <script type="application/ld+json" set:html={JSON.stringify(structured)} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <BrandBackdrop />
    <CursorTracker />
    <SiteHeader />
    {
      breadcrumb && breadcrumb.length > 0 && (
        <nav aria-label="Fil d'Ariane" class="relative z-10 mx-auto w-full max-w-6xl px-4 py-3 text-sm text-marine/80 md:px-6">
          <ol class="flex flex-wrap items-center gap-2">
            {breadcrumb.map((item, i) => (
              <li class="flex items-center gap-2">
                {i > 0 && <span class="text-marine/40">/</span>}
                {item.href ? (
                  <a href={item.href} class="underline decoration-marine/30 underline-offset-2 hover:text-marine">
                    {item.label}
                  </a>
                ) : (
                  <span class="font-medium text-marine">{item.label}</span>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <main id="contenu-principal" class="relative z-10 flex-1">
      <slot />
    </main>
    <SiteFooter />
    <script is:inline>
      (function () {
        function initScrollReveals() {
          var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          var main = document.querySelector("main");
          if (!main) return;

          var seen = new WeakSet();
          var targets = [];

          function add(el) {
            if (!(el instanceof HTMLElement)) return;
            if (seen.has(el)) return;
            seen.add(el);
            targets.push(el);
            el.classList.add("reveal-on-scroll");
            var delay = el.getAttribute("data-reveal-delay");
            if (delay && !reduce) el.style.setProperty("--reveal-delay", delay + (delay.endsWith("ms") ? "" : "ms"));
          }

          if (reduce) {
            Array.from(main.children).forEach(function (el) {
              if (!(el instanceof HTMLElement)) return;
              if (el.hasAttribute("data-reveal-skip")) return;
              el.classList.add("reveal-on-scroll", "is-inview");
            });
            Array.from(main.querySelectorAll("[data-reveal]")).forEach(function (el) {
              if (!(el instanceof HTMLElement)) return;
              el.classList.add("reveal-on-scroll", "is-inview");
            });
            document.querySelectorAll("footer [data-reveal]").forEach(function (el) {
              if (!(el instanceof HTMLElement)) return;
              el.classList.add("reveal-on-scroll", "is-inview");
            });
            return;
          }

          Array.from(main.children).forEach(function (el) {
            if (!(el instanceof HTMLElement)) return;
            if (el.hasAttribute("data-reveal-skip")) return;
            add(el);
          });

          main.querySelectorAll("[data-reveal]").forEach(add);
          document.querySelectorAll("footer [data-reveal]").forEach(add);

          var io = new IntersectionObserver(
            function (entries) {
              for (var i = 0; i < entries.length; i++) {
                var en = entries[i];
                var t = en.target;
                if (!(t instanceof HTMLElement)) continue;
                if (en.isIntersecting) t.classList.add("is-inview");
                else t.classList.remove("is-inview");
              }
            },
            { threshold: 0.1, rootMargin: "0px 0px -6% 0px" },
          );

          for (var j = 0; j < targets.length; j++) io.observe(targets[j]);
        }

        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", initScrollReveals);
        else initScrollReveals();
      })();
    </script>
    <script is:inline>
      (function () {
        /**
         * offsetLeft est relatif à offsetParent (souvent un ancêtre positionné), pas au
         * conteneur overflow — on aligne donc chaque enfant via getBoundingClientRect().
         */
        function snapCarouselStep(viewport, direction) {
          var v = viewport.getBoundingClientRect();
          var sl = viewport.scrollLeft;
          var kids = viewport.children;
          var best = null;
          var i;
          if (direction > 0) {
            for (i = 0; i < kids.length; i++) {
              var rN = kids[i].getBoundingClientRect();
              var tsN = sl + (rN.left - v.left);
              if (tsN > sl + 6) {
                if (best === null || tsN < best) best = tsN;
              }
            }
            if (best !== null) viewport.scrollTo({ left: best, behavior: "smooth" });
            else viewport.scrollTo({ left: viewport.scrollWidth - viewport.clientWidth, behavior: "smooth" });
          } else {
            for (i = 0; i < kids.length; i++) {
              var rP = kids[i].getBoundingClientRect();
              var tsP = sl + (rP.left - v.left);
              if (tsP < sl - 6) {
                if (best === null || tsP > best) best = tsP;
              }
            }
            if (best !== null) viewport.scrollTo({ left: Math.max(0, best), behavior: "smooth" });
            else viewport.scrollTo({ left: 0, behavior: "smooth" });
          }
        }

        document.addEventListener(
          "click",
          function (e) {
            var prev = e.target && e.target.closest && e.target.closest("[data-snap-prev]");
            var next = e.target && e.target.closest && e.target.closest("[data-snap-next]");
            if (!prev && !next) return;
            var id = prev ? prev.getAttribute("data-snap-prev") : next.getAttribute("data-snap-next");
            var viewport = id ? document.getElementById(id) : null;
            if (!viewport || !viewport.children || !viewport.children.length) return;
            e.preventDefault();
            snapCarouselStep(viewport, prev ? -1 : 1);
          },
          false,
        );
      })();
    </script>
  </body>
</html>
