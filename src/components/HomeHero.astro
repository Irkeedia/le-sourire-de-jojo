---
import HomeAudienceCard from "@/components/HomeAudienceCard.astro";

const heroLogo = "/images/logo-sourire-de-jojo.png";
/** Photo d’arrière-plan — duo / salon accueil. */
const heroImage = "/images/personneagé.png";
---

<section
  class="relative z-[1] border-b border-marine/10 bg-cream"
  aria-labelledby="hero-accueil-title"
  data-reveal-skip
>
  <div class="relative flex min-h-0 flex-col overflow-hidden md:min-h-[calc(100svh-5rem)]">
    
    <!-- DESKTOP : Background Photo + Voile -->
    <div class="pointer-events-none absolute inset-0 z-0 hidden select-none md:block" aria-hidden="true">
      <img
        src={heroImage}
        alt=""
        width={1856}
        height={2298}
        class="h-full min-h-full w-full object-cover md:object-[center_24%]"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-cream/76 via-cream/58 to-cream/70"></div>
      <div
        class="absolute inset-0"
        style="background: radial-gradient(circle at 50% 46%, rgb(255 255 255 / 0.22), transparent 38%), linear-gradient(90deg, rgb(29 53 87 / 0.22), transparent 22%, transparent 78%, rgb(29 53 87 / 0.16));"
      >
      </div>
    </div>

    <!-- FLEURS DECO : Visibles à partir de md pour garder le mobile ultra clean -->
    <div class="pointer-events-none absolute inset-0 z-[1] hidden select-none md:block" aria-hidden="true">
      <img src="/images/assets%20fleur/2.png" alt="" width="256" height="256" class="absolute -right-4 top-0 h-64 w-64 object-contain opacity-[0.14]" />
      <img src="/images/assets%20fleur/5.png" alt="" width="200" height="200" class="absolute right-[18%] top-[8%] h-36 w-36 object-contain opacity-[0.1]" />
      <img src="/images/assets%20fleur/3.png" alt="" width="256" height="256" class="absolute -left-6 bottom-0 h-72 w-72 object-contain opacity-[0.13]" />
      <img src="/images/assets%20fleur/4.png" alt="" width="200" height="200" class="absolute bottom-[6%] left-[12%] h-40 w-40 object-contain opacity-[0.11]" />
      <img src="/images/assets%20fleur/8.png" alt="" width="220" height="220" class="absolute -bottom-2 -right-4 h-52 w-52 object-contain opacity-[0.12]" />
    </div>

    <!-- MOBILE : photo + logo intégré qui casse le cadre -->
    <div class="relative z-10 w-full px-4 pt-4 md:hidden">
      <div class="aspect-[4/3] w-full overflow-hidden rounded-[2rem] shadow-[0_8px_30px_rgba(29,53,87,0.12)] ring-1 ring-marine/10">
        <img
          src={heroImage}
          alt=""
          width={1856}
          height={2298}
          class="h-full w-full object-cover object-[center_30%]"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div
        class="absolute bottom-0 left-1/2 z-20 flex -translate-x-1/2 translate-y-1/2 items-center justify-center rounded-full bg-white p-2 shadow-[0_18px_42px_rgba(29,53,87,0.24)] ring-[8px] ring-cream"
        aria-hidden="true"
      >
        <img
          src={heroLogo}
          alt=""
          width="512"
          height="512"
          class="h-24 w-24 rounded-full object-cover"
          decoding="async"
        />
      </div>
    </div>

    <div class="relative z-[2] mx-auto flex w-full max-w-6xl flex-1 flex-col pb-10 md:justify-center md:px-6 md:py-8 lg:py-10">
      <!-- Intro : logo lisible + titre recentré en mobile -->
      <div class="relative z-20 mx-auto mt-16 flex w-full max-w-sm flex-col items-center px-5 text-center md:mt-0 md:max-w-none md:rounded-[2rem] md:border md:border-white/55 md:bg-white/35 md:px-8 md:py-6 md:shadow-[0_18px_60px_rgba(29,53,87,0.18)] md:ring-1 md:ring-white/30 md:backdrop-blur-2xl lg:px-10"
        data-reveal
        data-reveal-delay="0"
      >
        <div class="relative z-10 mb-5 hidden rounded-full bg-white p-2 shadow-[0_18px_42px_rgba(29,53,87,0.22)] ring-4 ring-cream md:block">
          <img
            src={heroLogo}
            alt="Le Sourire de Jojo"
            width="512"
            height="512"
            class="h-[5.5rem] w-[5.5rem] rounded-full object-cover"
            decoding="async"
          />
        </div>
        
        <div class="w-full md:mt-0">
          <h1
            id="hero-accueil-title"
            class="mx-auto w-full max-w-[19rem] text-center font-hero text-[1.55rem] font-semibold leading-[1.18] tracking-tight text-marine sm:max-w-[22rem] sm:text-[1.75rem] md:max-w-none md:text-[1.95rem] md:leading-tight lg:text-[2.2rem]"
            data-reveal
            data-reveal-delay="60"
          >
            Le Sourire de Jojo&nbsp;: accompagnement joyeux &amp; lien social à Corbarieu
          </h1>
          <p
            class="mx-auto mt-3 w-full max-w-[20rem] text-center text-[0.95rem] font-medium leading-relaxed text-marine/80 md:mt-3 md:max-w-none md:text-base md:text-marine/95"
            data-reveal
            data-reveal-delay="120"
          >
            Montauban, Corbarieu et le Tarn-et-Garonne — présence attentive, sans soins médicaux.
          </p>
        </div>
      </div>

      <!-- CAROUSEL CARDS -->
      <div class="relative w-full max-w-full">
        <div
          id="snap-hero-publics"
          class="mt-8 flex snap-x snap-mandatory gap-4 overflow-x-auto overflow-y-visible px-5 pb-4 [-ms-overflow-style:none] [scrollbar-width:none] max-md:scroll-pl-5 max-md:scroll-pr-5 max-md:touch-pan-x md:mt-8 md:grid md:grid-cols-3 md:items-stretch md:gap-8 md:overflow-visible md:p-0 md:touch-auto [&::-webkit-scrollbar]:hidden"
          aria-label="Publics accompagnés"
          data-reveal
          data-reveal-delay="180"
        >
          <div class="h-full w-full min-h-0 shrink-0 snap-center max-md:min-w-[min(21rem,calc(100vw-2.5rem))] md:snap-none">
            <HomeAudienceCard title="Pour nos aînés" description="Visites, partages, activités, carnet de sourires — rompre l’isolement sans forcer la conversation." href="#missions-aines" variant="rose">
              <svg slot="icon" class="h-8 w-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path d="M8 22V12a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10" stroke-linecap="round" /><path d="M10 10V8a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12" stroke-linecap="round" /><path d="M6 24h20" stroke-linecap="round" /><path d="M12 14h4M12 18h8" stroke-linecap="round" /><path d="M20 8v-1a2 2 0 0 1 2-2h0" stroke-linecap="round" /></svg>
            </HomeAudienceCard>
          </div>
          <div class="h-full w-full min-h-0 shrink-0 snap-center max-md:min-w-[min(21rem,calc(100vw-2.5rem))] md:snap-none">
            <HomeAudienceCard title="Pour les personnes immobilisées" description="Soutien enfants &amp; adultes, post-opératoire, maintien du lien — au lit ou au fauteuil, à votre rythme." href="#missions-immobilisation" variant="marine">
              <svg slot="icon" class="h-8 w-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path stroke-linecap="round" d="M6 20c2.5-5 8-8 14-8s11.5 3 14 8" /><path stroke-linecap="round" d="M16 12v11" /><circle cx="16" cy="10" r="2.5" /><circle cx="23" cy="9" r="3" fill="rgb(200 141 141 / 0.35)" stroke="currentColor" /><path stroke-linecap="round" d="M22 7s1-1.5 2.5-1" /></svg>
            </HomeAudienceCard>
          </div>
          <div class="h-full w-full min-h-0 shrink-0 snap-center max-md:min-w-[min(21rem,calc(100vw-2.5rem))] md:snap-none">
            <HomeAudienceCard title="Pour les personnes PMR" description="Sorties et activités adaptées : fauteuil, déambulateur, pauses, respect du rythme et maintien de l’autonomie." href="#missions-pmr" variant="marine">
              <svg slot="icon" class="h-8 w-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><circle cx="12" cy="8" r="2.5" /><path d="M12 11v6l3 3" stroke-linecap="round" /><circle cx="20.5" cy="22.5" r="4.5" /><path d="M14 17h5.5M20 14l-3 3" stroke-linecap="round" /></svg>
            </HomeAudienceCard>
          </div>
        </div>

        <!-- Flèches de navigation style Google, sous les cartes -->
        <div class="mt-1 flex items-center justify-center gap-3 md:hidden">
          <button
            type="button"
            class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-marine shadow-[0_6px_18px_rgba(29,53,87,0.14)] ring-1 ring-marine/10 transition hover:bg-cream active:scale-95"
            data-snap-prev="snap-hero-publics"
            aria-label="Précédent"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          </button>
          <button
            type="button"
            class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-marine shadow-[0_6px_18px_rgba(29,53,87,0.14)] ring-1 ring-marine/10 transition hover:bg-cream active:scale-95"
            data-snap-next="snap-hero-publics"
            aria-label="Suivant"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
          </button>
        </div>
      </div>
      
      <!-- Mobile scroll dots supprimé au profit des flèches -->

      <!-- QUOTE & ACTIONS -->
      <div class="relative z-10 mt-8 flex flex-col gap-5 px-4 md:mt-8 md:flex-col md:px-0">
        
        <!-- Quote -->
        <figure
          class="mx-auto w-full max-w-2xl shrink-0 rounded-2xl border border-marine/5 bg-white/60 px-6 py-6 text-center shadow-[0_8px_30px_rgba(29,53,87,0.06)] md:border-white/50 md:bg-white/35 md:px-8 md:py-6 md:shadow-[0_14px_44px_rgba(29,53,87,0.16)] md:ring-1 md:ring-white/30 md:backdrop-blur-2xl"
          data-reveal
          data-reveal-delay="100"
        >
          <blockquote class="font-hero text-[1rem] font-medium italic leading-relaxed text-marine md:text-lg lg:text-xl">
            «&nbsp;Dans l’aise ou dans la gêne, dans la maladie ou la santé… Tiens-toi droit et souris.&nbsp;»
          </blockquote>
          <figcaption class="mt-3 text-[0.65rem] font-bold uppercase tracking-widest text-marine/50 md:text-sm md:font-medium md:normal-case md:tracking-normal md:text-marine/75">
            Juste un sourire — Le Sourire de Jojo
          </figcaption>
        </figure>

        <!-- Buttons -->
        <div
          class="mx-auto mt-2 flex w-full max-w-xl flex-col gap-3 md:mt-2 md:flex-row md:flex-wrap md:items-center md:justify-center md:rounded-2xl md:border md:border-white/50 md:bg-white/30 md:px-5 md:py-4 md:shadow-[0_12px_36px_rgba(29,53,87,0.14)] md:ring-1 md:ring-white/30 md:backdrop-blur-2xl"
          data-reveal
          data-reveal-delay="160"
        >
          <a
            href="/contact#formulaire"
            class="flex min-h-[3.25rem] w-full items-center justify-center rounded-2xl bg-marine px-6 text-[0.95rem] font-semibold text-ivoire shadow-lg transition-all hover:bg-marine/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-marine md:min-h-[44px] md:w-auto md:flex-1 md:rounded-full md:text-sm"
          >
            Prendre contact
          </a>
          <a
            href="/offres"
            class="flex min-h-[3.25rem] w-full items-center justify-center rounded-2xl border-2 border-marine/10 bg-white px-6 text-[0.95rem] font-semibold text-marine shadow-sm transition hover:border-marine/30 hover:bg-marine/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-marine md:min-h-[44px] md:w-auto md:flex-1 md:rounded-full md:border-marine/20 md:text-sm"
          >
            Tarifs &amp; SAP
          </a>
          <a
            href="/a-propos#mon-histoire"
            class="flex min-h-[3.25rem] w-full items-center justify-center rounded-2xl bg-marine px-6 text-[0.95rem] font-semibold text-ivoire shadow-lg transition hover:bg-marine/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-marine md:min-h-[44px] md:w-auto md:flex-1 md:rounded-full md:text-sm"
          >
            Mon histoire
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
