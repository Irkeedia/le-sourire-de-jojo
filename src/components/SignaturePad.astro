---
interface Props {
  inputId: string;
  inputName?: string;
  label?: string;
}

const {
  inputId,
  inputName = "signature",
  label = "Signature du client",
} = Astro.props;
const canvasId = `${inputId}-canvas`;
---

<div class="signature-pad" data-signature-pad>
  <label for={canvasId} class="block text-sm font-medium text-marine">{label}</label>
  <p class="mt-1 text-sm text-marine/70">
    Signez directement dans le cadre avec le doigt, le stylet ou la souris.
  </p>
  <div class="mt-3 overflow-hidden rounded-2xl border border-marine/20 bg-white shadow-inner">
    <canvas
      id={canvasId}
      class="block h-44 w-full touch-none cursor-crosshair bg-white"
      aria-label={label}
      role="img"
      data-signature-canvas
    ></canvas>
  </div>
  <input id={inputId} name={inputName} type="hidden" data-signature-input />
  <div class="mt-3 flex flex-wrap items-center gap-3">
    <button
      type="button"
      class="rounded-full border border-marine/20 bg-white px-4 py-2 text-sm font-semibold text-marine shadow-sm transition hover:bg-marine/[0.04] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-marine"
      data-signature-clear
    >
      Effacer la signature
    </button>
    <span class="text-sm text-marine/65" data-signature-status>Signature non renseignée.</span>
  </div>
</div>

<script is:inline>
  (function () {
    function setupSignaturePad(root) {
      var canvas = root.querySelector("[data-signature-canvas]");
      var input = root.querySelector("[data-signature-input]");
      var clearBtn = root.querySelector("[data-signature-clear]");
      var status = root.querySelector("[data-signature-status]");
      if (!canvas || !input) return;

      var ctx = canvas.getContext("2d");
      if (!ctx) return;

      var drawing = false;
      var hasInk = false;
      var last = null;

      function configureContext() {
        ctx.lineCap = "round";
        ctx.lineJoin = "round";
        ctx.lineWidth = 2.6;
        ctx.strokeStyle = "#1d3557";
      }

      function resizeCanvas() {
        var previous = hasInk ? canvas.toDataURL("image/png") : "";
        var rect = canvas.getBoundingClientRect();
        var ratio = window.devicePixelRatio || 1;
        canvas.width = Math.max(1, Math.round(rect.width * ratio));
        canvas.height = Math.max(1, Math.round(rect.height * ratio));
        ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
        configureContext();

        if (previous) {
          var img = new Image();
          img.onload = function () {
            ctx.drawImage(img, 0, 0, rect.width, rect.height);
            input.value = canvas.toDataURL("image/png");
          };
          img.src = previous;
        }
      }

      function pointFromEvent(event) {
        var rect = canvas.getBoundingClientRect();
        return {
          x: event.clientX - rect.left,
          y: event.clientY - rect.top,
        };
      }

      function updateInput() {
        input.value = hasInk ? canvas.toDataURL("image/png") : "";
        if (status) status.textContent = hasInk ? "Signature prête pour le contrat." : "Signature non renseignée.";
        input.dispatchEvent(new Event("input", { bubbles: true }));
      }

      function start(event) {
        event.preventDefault();
        drawing = true;
        last = pointFromEvent(event);
        hasInk = true;
        try {
          canvas.setPointerCapture(event.pointerId);
        } catch (e) {}
        ctx.beginPath();
        ctx.arc(last.x, last.y, 1.3, 0, Math.PI * 2);
        ctx.fillStyle = "#1d3557";
        ctx.fill();
        updateInput();
      }

      function move(event) {
        if (!drawing || !last) return;
        event.preventDefault();
        var next = pointFromEvent(event);
        ctx.beginPath();
        ctx.moveTo(last.x, last.y);
        ctx.lineTo(next.x, next.y);
        ctx.stroke();
        last = next;
      }

      function end(event) {
        if (!drawing) return;
        event.preventDefault();
        drawing = false;
        last = null;
        updateInput();
      }

      function clear() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        hasInk = false;
        updateInput();
      }

      resizeCanvas();
      canvas.addEventListener("pointerdown", start);
      canvas.addEventListener("pointermove", move);
      canvas.addEventListener("pointerup", end);
      canvas.addEventListener("pointercancel", end);
      canvas.addEventListener("pointerleave", end);
      if (clearBtn) clearBtn.addEventListener("click", clear);
      window.addEventListener("resize", resizeCanvas, { passive: true });
    }

    function ready(fn) {
      if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", fn);
      else fn();
    }

    ready(function () {
      document.querySelectorAll("[data-signature-pad]").forEach(setupSignaturePad);
    });
  })();
</script>
