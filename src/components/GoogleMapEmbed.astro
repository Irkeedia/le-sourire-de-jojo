---
/**
 * Carte Google Maps toujours intégrée en iframe sur le site.
 *
 * Ordre de priorité pour l’URL de l’iframe :
 * 1. PUBLIC_GOOGLE_MAPS_EMBED_URL — URL complète copiée depuis Google Maps (Partager → Intégrer une carte).
 * 2. PUBLIC_GOOGLE_MAPS_API_KEY — Embed API v1 (place + q + zoom).
 * 3. Sinon — embed sans clé (paramètre output=embed, sujet à évolutions côté Google).
 */
interface Props {
  /** Texte accessible pour l’iframe */
  title?: string;
  class?: string;
  /** Requête lieu (priorité sur PUBLIC_GOOGLE_MAPS_EMBED_QUERY) */
  query?: string;
  /** Zoom 1–20 (défaut : env ou 9) — utilisé avec clé API ou embed sans clé */
  zoom?: number;
}

const {
  title = "Carte — zone d’intervention",
  class: className = "",
  query: queryProp,
  zoom: zoomProp,
} = Astro.props;

const customEmbedUrl = import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_URL?.trim();
const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY?.trim();
const envQuery = import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_QUERY?.trim();
const query = queryProp?.trim() || envQuery || "Montauban, Tarn-et-Garonne, France";

const envZoom = import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_ZOOM;
const zoomParsed = zoomProp ?? (envZoom != null && envZoom !== "" ? Number(envZoom) : NaN);
const zoom = Number.isFinite(zoomParsed) ? Math.min(20, Math.max(1, Math.round(zoomParsed))) : 9;

let embedSrc: string;
let embedMode: "custom" | "api" | "legacy" = "legacy";

if (customEmbedUrl) {
  embedSrc = customEmbedUrl;
  embedMode = "custom";
} else if (apiKey) {
  embedSrc = `https://www.google.com/maps/embed/v1/place?key=${encodeURIComponent(apiKey)}&q=${encodeURIComponent(query)}&zoom=${zoom}`;
  embedMode = "api";
} else {
  embedSrc = `https://www.google.com/maps?q=${encodeURIComponent(query)}&z=${zoom}&hl=fr&output=embed`;
  embedMode = "legacy";
}

---

<div class:list={["w-full", className]}>
  <div class="overflow-hidden rounded-2xl border border-marine/15 bg-marine/5 shadow-sm">
    <div class="relative aspect-[16/10] w-full min-h-[220px] md:min-h-[280px]">
      <iframe
        title={title}
        src={embedSrc}
        class="absolute inset-0 h-full w-full border-0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      />
    </div>
  </div>
  <p class="mt-3 text-center text-xs text-marine/60">Carte intégrée — Google Maps.</p>
  {
    embedMode === "legacy" && import.meta.env.DEV ? (
      <p class="mt-1 text-center text-[0.65rem] leading-snug text-marine/50">
        En prod : pour l’URL d’iframe officielle (Partager → Intégrer une carte), définir{" "}
        <code class="rounded bg-marine/10 px-1">PUBLIC_GOOGLE_MAPS_EMBED_URL</code> dans{" "}
        <code class="rounded bg-marine/10 px-1">.env</code>.
      </p>
    ) : null
  }
</div>
