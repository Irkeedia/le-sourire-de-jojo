---
---

<div id="jojo-cursor-root" class="jojo-cursor-root" aria-hidden="true">
  <!-- Curseur instantané : petit point -->
  <div id="jojo-cursor-dot" class="jojo-cursor-dot"></div>
</div>

<style is:global>
  .jojo-cursor-root {
    position: fixed;
    inset: 0;
    z-index: 2147483646;
    pointer-events: none;
    contain: layout style paint;
  }

  .jojo-cursor-dot {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    will-change: transform;
    transform: translate3d(-100px, -100px, 0);
    transition: opacity 0.25s ease;
    opacity: 0;
  }

  .jojo-cursor-dot {
    width: 8px;
    height: 8px;
    margin: -4px 0 0 -4px;
    border-radius: 9999px;
    background: var(--color-marine, #1d3557);
    box-shadow:
      0 0 0 2px rgb(245 243 231 / 0.95),
      0 2px 8px rgb(29 53 87 / 0.35);
    transition:
      width 0.2s ease,
      height 0.2s ease,
      margin 0.2s ease,
      opacity 0.25s ease,
      background 0.2s ease;
  }

  .jojo-cursor-active .jojo-cursor-dot {
    width: 12px;
    height: 12px;
    margin: -6px 0 0 -6px;
    background: var(--color-marine, #1d3557);
  }

  .jojo-cursor-ready .jojo-cursor-dot {
    opacity: 1;
  }

  @media (hover: hover) and (pointer: fine) {
    html.jojo-cursor-on,
    html.jojo-cursor-on body {
      cursor: none;
    }

    html.jojo-cursor-on input,
    html.jojo-cursor-on textarea,
    html.jojo-cursor-on select,
    html.jojo-cursor-on [contenteditable="true"] {
      cursor: text;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .jojo-cursor-root {
      display: none;
    }
  }

</style>

<script is:inline>
  (function () {
    if (typeof window === "undefined") return;

    var fineHover =
      window.matchMedia &&
      window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    if (!fineHover) return;

    var root = document.getElementById("jojo-cursor-root");
    var dot = document.getElementById("jojo-cursor-dot");
    if (!root || !dot) return;

    document.documentElement.classList.add("jojo-cursor-on");

    var fx = window.innerWidth / 2;
    var fy = window.innerHeight / 2;
    var ready = false;

    function setActive(on) {
      root.classList.toggle("jojo-cursor-active", !!on);
    }

    function placeDot() {
      dot.style.transform = "translate3d(" + fx + "px, " + fy + "px, 0)";
    }

    document.addEventListener(
      "mousemove",
      function (e) {
        fx = e.clientX;
        fy = e.clientY;
        if (!ready) {
          ready = true;
          root.classList.add("jojo-cursor-ready");
        }
        placeDot();
      },
      { passive: true },
    );

    document.addEventListener("mouseleave", function () {
      root.classList.remove("jojo-cursor-ready");
    });

    document.addEventListener("mouseenter", function () {
      if (ready) root.classList.add("jojo-cursor-ready");
    });

    var INTERACTIVE_SELECTOR =
      'a, button, [role="button"], input[type="submit"], input[type="button"], summary, label, select, [data-mobile-nav-link]';

    document.addEventListener(
      "mouseover",
      function (e) {
        var target = e.target;
        if (target && typeof target.closest === "function" && target.closest(INTERACTIVE_SELECTOR)) {
          setActive(true);
        }
      },
      { passive: true },
    );

    document.addEventListener(
      "mouseout",
      function (e) {
        var target = e.target;
        if (target && typeof target.closest === "function" && target.closest(INTERACTIVE_SELECTOR)) {
          setActive(false);
        }
      },
      { passive: true },
    );

  })();
</script>
