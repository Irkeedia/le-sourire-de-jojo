---
import { TARIF_HORAIRE_BRUT_EUR } from "@/lib/tarif";

const rate = TARIF_HORAIRE_BRUT_EUR;

const durees: { hours: number; label: string }[] = [
  { hours: 0.5, label: "30 minutes" },
  { hours: 0.75, label: "45 minutes" },
  { hours: 1, label: "1 heure" },
  { hours: 1.5, label: "1 h 30" },
  { hours: 2, label: "2 heures" },
  { hours: 3, label: "3 heures" },
  { hours: 4, label: "4 heures" },
];

const defaultHours = 1;
const initialBrut = defaultHours * rate;
const initialNet = initialBrut * 0.5;

function fmtEuro(n: number) {
  return new Intl.NumberFormat("fr-FR", { style: "currency", currency: "EUR" }).format(n);
}
---

<section
  id="cost-simulator-root"
  class="rounded-2xl border border-marine/15 bg-white/90 p-6 shadow-sm"
  data-hourly-rate={String(rate)}
  aria-labelledby="sim-title"
>
  <h2 id="sim-title" class="font-display text-2xl text-marine">
    Simulateur de coût (crédit d’impôt 50&nbsp;%)
  </h2>
  <p class="mt-2 text-marine/85">
    Choisissez une durée : le montant brut est calculé sur la base de <strong class="text-marine"
      >{rate}&nbsp;€ / h</strong
    > indicatif, puis le coût net après crédit d’impôt sur les dépenses éligibles (réglementation en vigueur).
  </p>
  <div class="mt-6 grid gap-4 md:grid-cols-2">
    <div>
      <label for="sim-duree" class="block text-sm font-medium text-marine"> Durée </label>
      <select
        id="sim-duree"
        data-sim-duree
        class="mt-1 w-full rounded-lg border border-marine/25 bg-ivoire px-3 py-2 text-marine focus:border-marine focus:outline-none focus:ring-2 focus:ring-marine/30"
      >
        {
          durees.map((d) => (
            <option value={d.hours} selected={d.hours === defaultHours}>
              {d.label}
            </option>
          ))
        }
      </select>
      <p class="mt-3 text-sm text-marine/80">
        Montant brut estimé : <span id="sim-brut-display" data-sim-brut class="font-semibold text-marine">{fmtEuro(initialBrut)}</span>
      </p>
    </div>
    <div class="rounded-xl bg-sauge/25 p-4">
      <p class="text-sm font-medium text-marine">Coût net estimé après 50&nbsp;%</p>
      <p class="mt-2 font-display text-3xl text-marine" id="sim-net" data-sim-net aria-live="polite">{fmtEuro(initialNet)}</p>
      <p class="mt-2 text-xs text-marine/70">
        Simulation indicative — vérifiez votre situation avec un conseiller ou les informations officielles des
        services à la personne.
      </p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function fmt(n) {
      return new Intl.NumberFormat("fr-FR", { style: "currency", currency: "EUR" }).format(n);
    }

    function bind(root) {
      if (!root || root.getAttribute("data-sim-bound") === "1") return;
      var rate = parseFloat(root.getAttribute("data-hourly-rate") || "35");
      if (Number.isNaN(rate)) rate = 35;
      var select = root.querySelector("[data-sim-duree]");
      var brutOut = root.querySelector("[data-sim-brut]");
      var netOut = root.querySelector("[data-sim-net]");
      if (!select || !brutOut || !netOut) return;
      root.setAttribute("data-sim-bound", "1");

      function update() {
        var hours = Math.max(0, parseFloat(select.value) || 0);
        var brut = hours * rate;
        var net = brut * 0.5;
        brutOut.textContent = fmt(brut);
        netOut.textContent = fmt(net);
      }

      select.addEventListener("change", update);
      select.addEventListener("input", update);
      update();
    }

    function init() {
      var root = document.getElementById("cost-simulator-root");
      bind(root);
    }

    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>
