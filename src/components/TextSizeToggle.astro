---
interface Props {
  variant?: "default" | "compact";
}
const { variant = "default" } = Astro.props;
const compact = variant === "compact";
---

<div class:list={["flex items-center gap-2", compact && "justify-center"]}>
  <span class="sr-only" id={`text-size-label-${variant}`}>Taille du texte</span>
  <button
    type="button"
    class:list={[
      "rounded-lg border border-marine/25 bg-white px-3 font-semibold text-marine shadow-sm transition hover:border-marine hover:bg-marine hover:text-ivoire focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-marine",
      compact ? "py-2.5 text-base min-h-[44px] min-w-[44px]" : "py-2 text-sm",
    ]}
    data-text-normal
    aria-pressed="true"
    aria-controls="contenu-principal"
    aria-describedby={`text-size-label-${variant}`}
  >
    A
  </button>
  <button
    type="button"
    class:list={[
      "rounded-lg border border-marine/25 bg-white px-3 font-semibold text-marine shadow-sm transition hover:border-marine hover:bg-marine hover:text-ivoire focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-marine",
      compact ? "py-2.5 text-xl min-h-[44px] min-w-[44px]" : "py-2 text-lg",
    ]}
    data-text-large
    aria-pressed="false"
    aria-controls="contenu-principal"
    aria-describedby={`text-size-label-${variant}`}
  >
    A+
  </button>
</div>

<script>
  (function () {
    const KEY = "lsdj-text-scale";
    const root = document.documentElement;

    function apply(scale) {
      root.style.setProperty("--font-scale", String(scale));
      document.querySelectorAll("[data-text-normal]").forEach(function (el) {
        el.setAttribute("aria-pressed", scale === 1 ? "true" : "false");
      });
      document.querySelectorAll("[data-text-large]").forEach(function (el) {
        el.setAttribute("aria-pressed", scale > 1 ? "true" : "false");
      });
    }

    if (sessionStorage.getItem(KEY) === "1.15") apply(1.15);

    document.querySelectorAll("[data-text-normal]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        sessionStorage.removeItem(KEY);
        apply(1);
      });
    });
    document.querySelectorAll("[data-text-large]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        sessionStorage.setItem(KEY, "1.15");
        apply(1.15);
      });
    });
  })();
</script>
