---
interface Props {
  class?: string;
  position?: "top" | "bottom";
}
const { class: className = "", position = "bottom" } = Astro.props;
---

<div
  class:list={[
    "pointer-events-none absolute overflow-hidden opacity-[0.34] select-none",
    position === "top"
      ? "top-0 right-0 h-56 w-56 -translate-y-1/4 translate-x-1/4 md:h-72 md:w-72"
      : "bottom-0 left-0 h-64 w-64 -translate-x-1/4 translate-y-1/4 md:h-80 md:w-80",
    className,
  ]}
  aria-hidden="true"
>
  <svg viewBox="0 0 260 260" class="h-full w-full">
    <path d="M132 22c-13 50-18 103-14 178" stroke="#8FA892" stroke-width="5" stroke-linecap="round" />
    <path d="M119 106c-38-20-70-11-92 20 39 15 70 7 92-20Z" fill="#8FA892" opacity="0.45" />
    <path d="M127 150c38-23 72-15 97 18-42 16-74 10-97-18Z" fill="#8FA892" opacity="0.4" />
    <g opacity="0.85">
      <circle cx="134" cy="62" r="18" fill="#E9C46A" opacity="0.8" />
      <ellipse cx="134" cy="31" rx="17" ry="30" fill="#E9C46A" opacity="0.55" />
      <ellipse cx="134" cy="93" rx="17" ry="30" fill="#E9C46A" opacity="0.55" />
      <ellipse cx="103" cy="62" rx="30" ry="17" fill="#E9C46A" opacity="0.55" />
      <ellipse cx="165" cy="62" rx="30" ry="17" fill="#E9C46A" opacity="0.55" />
      <circle cx="134" cy="62" r="7" fill="#1D3557" opacity="0.45" />
    </g>
    <g opacity="0.8">
      <circle cx="82" cy="144" r="15" fill="#C88D8D" />
      <ellipse cx="82" cy="118" rx="15" ry="25" fill="#C88D8D" opacity="0.5" />
      <ellipse cx="82" cy="170" rx="15" ry="25" fill="#C88D8D" opacity="0.5" />
      <ellipse cx="56" cy="144" rx="25" ry="15" fill="#C88D8D" opacity="0.5" />
      <ellipse cx="108" cy="144" rx="25" ry="15" fill="#C88D8D" opacity="0.5" />
    </g>
    <g opacity="0.78">
      <circle cx="182" cy="172" r="16" fill="#457B9D" />
      <ellipse cx="182" cy="146" rx="16" ry="26" fill="#457B9D" opacity="0.45" />
      <ellipse cx="182" cy="198" rx="16" ry="26" fill="#457B9D" opacity="0.45" />
      <ellipse cx="156" cy="172" rx="26" ry="16" fill="#457B9D" opacity="0.45" />
      <ellipse cx="208" cy="172" rx="26" ry="16" fill="#457B9D" opacity="0.45" />
    </g>
    <path
      d="M187 84c20-22 48-12 53 13-23-5-37 7-53-13Z"
      fill="#A29BFE"
      opacity="0.45"
    />
    <path
      d="M52 205c22-14 45-9 60 12-27 6-48 3-60-12Z"
      fill="#E76F51"
      opacity="0.4"
    />
  </svg>
