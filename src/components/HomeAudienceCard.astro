---
interface Props {
  title: string;
  description: string;
  href: string;
  variant: "rose" | "marine";
}

const { title, description, href, variant } = Astro.props;

const btn =
  variant === "rose"
    ? "bg-rose-vieux text-ivoire shadow-md hover:bg-rose-vieux/90 focus-visible:outline-rose-vieux"
    : "bg-marine text-ivoire shadow-md hover:bg-marine/90 focus-visible:outline-marine";
---

<article
  class="jojo-card-lift flex h-full min-h-0 w-full flex-col rounded-xl border border-marine/[0.06] bg-white p-5 shadow-[0_14px_48px_rgba(29,53,87,0.09)] transition-[transform,box-shadow,border-color] duration-300 ease-out will-change-transform max-md:min-h-0 md:min-h-[22rem] md:rounded-2xl md:p-8"
>
  <div
    class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-sauge/20 text-marine md:mb-5 md:h-14 md:w-14 md:rounded-2xl"
    aria-hidden="true"
  >
    <slot name="icon" />
  </div>
  <h2
    class="font-hero text-base font-semibold uppercase tracking-[0.1em] text-marine sm:text-lg md:text-xl md:tracking-[0.12em]"
  >
    {title}
  </h2>
  <p class="mt-3 min-h-0 flex-1 text-sm leading-relaxed text-marine/85 max-md:leading-relaxed md:mt-4 md:text-base">
    {description}
  </p>
  <div class="mt-auto w-full pt-5 md:pt-8">
    <a
      href={href}
      class:list={[
        "inline-flex w-full items-center justify-center rounded-xl px-5 py-3.5 text-center text-sm font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 md:rounded-2xl",
        btn,
      ]}
    >
      En savoir plus
    </a>
  </div>
</article>
