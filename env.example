# URL canonique du site (HTTPS en production)
PUBLIC_SITE_URL=https://www.votre-domaine.fr

# Indexation moteurs de recherche : par défaut le site est hors index (noindex) si absent ou != true
# Mettre true uniquement quand vous souhaitez apparaître sur Google, etc.
PUBLIC_ALLOW_INDEXING=false

# Google Maps — carte toujours intégrée en iframe sur le site
# Option A (recommandé sans API) : URL complète du champ src de l’iframe (Google Maps → Partager → Intégrer une carte)
# PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
#
# Option B : clé Google Cloud + Maps Embed API (rester sur v1/place)
PUBLIC_GOOGLE_MAPS_API_KEY=
# Lieu si pas d’URL personnalisée et pas de clé : recherche + output=embed (défaut ci-dessous)
PUBLIC_GOOGLE_MAPS_EMBED_QUERY=Montauban, Tarn-et-Garonne, France
# Zoom 1–20 (optionnel, défaut 9 ; ignoré si PUBLIC_GOOGLE_MAPS_EMBED_URL est une URL fixe)
PUBLIC_GOOGLE_MAPS_EMBED_ZOOM=9

# Contact : réception des messages
CONTACT_TO_EMAIL=contact@votre-domaine.fr

# SMTP (TLS recommandé en production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Persistance optionnelle des messages (MongoDB)
MONGODB_URI=

# --- Sécurité (optionnel) ---
# HSTS : uniquement si le site est servi en HTTPS derrière un proxy fiable
# qui transmet X-Forwarded-Proto: https
HSTS_ENABLE=false

# Content-Security-Policy : en prod uniquement (pas en astro dev)
# Phase test : CSP_REPORT_ONLY=true + CSP_REPORT_URI=https://report.example/csp
CSP_REPORT_ONLY=false
CSP_REPORT_URI=

# Anti-abus formulaire contact (instance Node unique ; utiliser Redis/WAF en cluster)
CONTACT_RATE_LIMIT=12
CONTACT_RATE_WINDOW_MS=900000
